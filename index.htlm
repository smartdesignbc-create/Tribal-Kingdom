<div class="toast" id="toast"></div>

<script>
/* ============ STATE ============ */
let idCounters = { mr:1043, ins:232, ct:15, dl:3082 };
let state = {
  maintenance: [
    {id:'MR-1042', date:'2026-06-28', property:'Tribal Kingdom — Main House', area:'Roof / Gutters', fault:'Blocked downpipe causing overflow near east wing', priority:'High', assignedTo:'Rapid Roofing Co.', status:'Waiting Contractor', photo:null},
    {id:'MR-1041', date:'2026-06-25', property:'Tribal Kingdom — Guest Cottage', area:'Electrical', fault:'Outdoor lighting circuit tripping intermittently', priority:'Medium', assignedTo:'T. Naidoo (Staff)', status:'In Progress', photo:null},
    {id:'MR-1039', date:'2026-06-18', property:'Tribal Kingdom — Main House', area:'Irrigation', fault:'Zone 3 sprinkler valve not closing', priority:'Medium', assignedTo:'GreenScape Contractors', status:'Overdue', photo:null},
    {id:'MR-1035', date:'2026-06-10', property:'Tribal Kingdom — Staff Quarters', area:'Plumbing', fault:'Slow drain in kitchen sink', priority:'Low', assignedTo:'M. Dlamini (Staff)', status:'Completed', photo:null}
  ],
  inspections: [
    {id:'INS-0231', date:'2026-06-29', property:'Tribal Kingdom — Main House', inspector:'B. Retief', good:17, fair:2, poor:1, comments:''},
    {id:'INS-0227', date:'2026-06-15', property:'Tribal Kingdom — Guest Cottage', inspector:'B. Retief', good:15, fair:3, poor:0, comments:''}
  ],
  contractors: [
    {id:'CT-014', name:'J. Botha', company:'Rapid Roofing Co.', scope:'Gutter clearance and downpipe repair — east wing', start:'2026-07-02', expected:'2026-07-04', status:'Working'},
    {id:'CT-011', name:'S. Naidoo', company:'GreenScape Contractors', scope:'Irrigation zone 3 valve replacement', start:'2026-06-20', expected:'2026-06-22', status:'Outstanding'},
    {id:'CT-009', name:'R. Adams', company:'SecureView CCTV', scope:'Quarterly camera servicing, 12 units', start:'2026-06-05', expected:'2026-06-06', status:'Awaiting Sign-off'}
  ],
  deliveries: [
    {id:'DL-3081', date:'2026-07-02', supplier:'BuildRight Hardware', items:'Roof flashing, sealant, gutter brackets', qty:'6 boxes', received:'T. Naidoo'},
    {id:'DL-3079', date:'2026-07-01', supplier:'Garden Wholesale', items:'Irrigation valves, mulch', qty:'3 pallets', received:'M. Dlamini'}
  ],
  activity: [
    {time:'08:41', text:'Maintenance MR-1042 moved to Waiting Contractor'},
    {time:'Yesterday', text:'Inspection INS-0231 completed at Main House'},
    {time:'Yesterday', text:'Delivery DL-3081 received from BuildRight Hardware'}
  ]
};
const categories = ["Roof","Gutters","Downpipes","Stormwater Drains","External Walls","Doors","Windows","Gates","Fencing","Paving","Driveways","Parking Areas","Gardens","Trees","Irrigation","Lighting","CCTV Cameras","Fire Equipment","Emergency Signage","General Housekeeping"];
let currentConditions = {};
let editingMaintenanceId = null;
let editingContractorId = null;
let editingDeliveryId = null;
let pendingPhoto = { mm: null };
const upcomingInspectionsCount = 3;

/* ============ HELPERS ============ */
function statusClass(s){ return 'status-' + s.replace(/[^A-Za-z]/g,''); }
function todayStr(){ return new Date().toISOString().slice(0,10); }
function esc(s){ return (s||'').toString().replace(/</g,'&lt;'); }
function showToast(msg){
  const t = document.getElementById('toast');
  t.textContent = msg; t.classList.add('show');
  clearTimeout(window._toastTimer);
  window._toastTimer = setTimeout(()=> t.classList.remove('show'), 2200);
}
function addActivity(text){
  state.activity.unshift({time:'Just now', text});
  state.activity = state.activity.slice(0,6);
}
function toggleForm(id){
  const el = document.getElementById(id);
  el.style.display = el.style.display === 'none' ? 'block' : 'none';
}
function cancelForm(id){
  document.getElementById(id).style.display = 'none';
  if(id==='maintenanceForm') resetMaintenanceForm();
  if(id==='contractorForm') resetContractorForm();
  if(id==='deliveryForm') resetDeliveryForm();
}

/* ============ NAV ============ */
function showScreen(id){
  document.querySelectorAll('.screen').forEach(s => s.classList.remove('active'));
  document.getElementById('screen-' + id).classList.add('active');
  document.querySelectorAll('.sidebar').forEach(s => s.classList.remove('open'));
  document.querySelectorAll('.scrim').forEach(s => s.classList.remove('show'));
  window.scrollTo(0,0);
  renderAll();
}
function openSidebar(name){
  document.getElementById('sidebar-' + name).classList.add('open');
  document.querySelector('#screen-' + name + ' .scrim').classList.add('show');
}
function closeSidebar(){
  document.querySelectorAll('.sidebar').forEach(s => s.classList.remove('open'));
  document.querySelectorAll('.scrim').forEach(s => s.classList.remove('show'));
}

/* ============ PHOTO HANDLING ============ */
function handlePhoto(evt, prefix){
  const file = evt.target.files[0];
  if(!file) return;
  const reader = new FileReader();
  reader.onload = function(e){
    pendingPhoto[prefix] = e.target.result;
    renderPhotoPreview(prefix);
    showToast('Photo attached');
  };
  reader.readAsDataURL(file);
}
function renderPhotoPreview(prefix){
  const box = document.getElementById(prefix + '_photo_preview');
  if(!pendingPhoto[prefix]){ box.innerHTML=''; return; }
  box.innerHTML = '<div class="photo-preview"><img src="'+pendingPhoto[prefix]+'"><span style="font-size:12px;color:var(--navy-500);">Photo attached</span><span class="x" onclick="removePendingPhoto(\''+prefix+'\')">Remove</span></div>';
}
function removePendingPhoto(prefix){ pendingPhoto[prefix] = null; renderPhotoPreview(prefix); }

/* ============ MAINTENANCE ============ */
function resetMaintenanceForm(){
  editingMaintenanceId = null;
  document.getElementById('mmFormTitle').textContent = 'New Maintenance Issue';
  document.getElementById('mmSaveBtn').textContent = 'Save Issue';
  document.getElementById('mm_status_field').style.display = 'none';
  document.getElementById('mm_property').value = '';
  document.getElementById('mm_area').value = '';
  document.getElementById('mm_fault').value = '';
  document.getElementById('mm_priority').value = 'Medium';
  document.getElementById('mm_assigned').value = '';
  pendingPhoto.mm = null;
  renderPhotoPreview('mm');
}
function saveMaintenance(){
  const property = document.getElementById('mm_property').value.trim();
  const fault = document.getElementById('mm_fault').value.trim();
  if(!property || !fault){ showToast('Add a property and fault description'); return; }
  const area = document.getElementById('mm_area').value.trim();
  const priority = document.getElementById('mm_priority').value;
  const assignedTo = document.getElementById('mm_assigned').value.trim() || 'Unassigned';

  if(editingMaintenanceId){
    const rec = state.maintenance.find(m => m.id === editingMaintenanceId);
    rec.property = property; rec.area = area; rec.fault = fault; rec.priority = priority; rec.assignedTo = assignedTo;
    rec.status = document.getElementById('mm_status').value;
    if(pendingPhoto.mm) rec.photo = pendingPhoto.mm;
    addActivity('Maintenance ' + rec.id + ' updated');
    showToast('Maintenance issue updated');
  } else {
    const id = 'MR-' + (idCounters.mr++);
    state.maintenance.unshift({id, date: todayStr(), property, area, fault, priority, assignedTo, status:'Open', photo: pendingPhoto.mm});
    addActivity('Maintenance ' + id + ' logged');
    showToast('Maintenance issue saved — see it highlighted in the table below');
    lastSavedMaintenanceId = id;
  }
  document.getElementById('maintenanceForm').style.display = 'none';
  resetMaintenanceForm();
  renderAll();
  const table = document.getElementById('maintenanceTable');
  if(table) table.scrollIntoView({behavior:'smooth', block:'center'});
}
let lastSavedMaintenanceId = null;
function editMaintenance(id){
  const rec = state.maintenance.find(m => m.id === id);
  editingMaintenanceId = id;
  document.getElementById('maintenanceForm').style.display = 'block';
  document.getElementById('mmFormTitle').textContent = 'Edit Maintenance Issue — ' + id;
  document.getElementById('mmSaveBtn').textContent = 'Update Issue';
  document.getElementById('mm_status_field').style.display = 'block';
  document.getElementById('mm_property').value = rec.property;
  document.getElementById('mm_area').value = rec.area;
  document.getElementById('mm_fault').value = rec.fault;
  document.getElementById('mm_priority').value = rec.priority;
  document.getElementById('mm_assigned').value = rec.assignedTo;
  document.getElementById('mm_status').value = rec.status;
  pendingPhoto.mm = rec.photo;
  renderPhotoPreview('mm');
  window.scrollTo(0,0);
}
function deleteMaintenance(id){
  if(!confirm('Delete maintenance record ' + id + '?')) return;
  state.maintenance = state.maintenance.filter(m => m.id !== id);
  addActivity('Maintenance ' + id + ' deleted');
  showToast('Deleted');
  renderAll();
}
function updateMaintenanceStatus(id, val){
  const rec = state.maintenance.find(m => m.id === id);
  rec.status = val;
  addActivity('Maintenance ' + id + ' set to ' + val);
  showToast('Status updated');
  renderAll();
}
function renderMaintenance(){
  const tbody = document.getElementById('maintenanceTable');
  if(!tbody) return;
  tbody.innerHTML = state.maintenance.map(m => `
    <tr ${m.id === lastSavedMaintenanceId ? 'style="background:var(--gold-50); box-shadow:inset 3px 0 0 var(--gold-500);"' : ''}>
      <td data-label="ID" class="mono">${m.id}</td>
      <td data-label="Property">${esc(m.property)}</td>
      <td data-label="Area">${esc(m.area)}</td>
      <td data-label="Fault">${esc(m.fault)}${m.photo ? '<span class="cam-icon">📷</span>' : ''}</td>
      <td data-label="Priority">${m.priority}</td>
      <td data-label="Assigned">${esc(m.assignedTo)}</td>
      <td data-label="Status">
        <select class="status-select ${statusClass(m.status)}" onchange="updateMaintenanceStatus('${m.id}', this.value)">
          ${['Open','In Progress','Waiting Contractor','Waiting Parts','Completed','Overdue'].map(s=>`<option ${s===m.status?'selected':''}>${s}</option>`).join('')}
        </select>
      </td>
      <td data-label="Actions"><div class="row-actions">
        <button class="icon-btn" onclick="editMaintenance('${m.id}')">Edit</button>
        <button class="icon-btn danger" onclick="deleteMaintenance('${m.id}')">Delete</button>
      </div></td>
    </tr>`).join('');
}

/* ============ INSPECTIONS ============ */
function renderCategoryChecklist(){
  const box = document.getElementById('ii_categories');
  const prevScroll = box.scrollTop;
  box.innerHTML = categories.map(cat => `
    <div class="condition-row">
      <span>${cat}</span>
      <div class="cond-btns">
        <button type="button" class="cond-btn good ${currentConditions[cat]==='Good'?'sel':''}" onclick="setCondition('${cat}','Good')">Good</button>
        <button type="button" class="cond-btn fair ${currentConditions[cat]==='Fair'?'sel':''}" onclick="setCondition('${cat}','Fair')">Fair</button>
        <button type="button" class="cond-btn poor ${currentConditions[cat]==='Poor'?'sel':''}" onclick="setCondition('${cat}','Poor')">Poor</button>
      </div>
    </div>`).join('');
  box.scrollTop = prevScroll;
}
function setCondition(cat, val){ currentConditions[cat] = val; renderCategoryChecklist(); }
function saveInspection(){
  const property = document.getElementById('ii_property').value.trim();
  const inspector = document.getElementById('ii_inspector').value.trim();
  if(!property || !inspector){ showToast('Add a property and inspector'); return; }
  const date = document.getElementById('ii_date').value || todayStr();
  const vals = Object.values(currentConditions);
  const good = vals.filter(v=>v==='Good').length;
  const fair = vals.filter(v=>v==='Fair').length;
  const poor = vals.filter(v=>v==='Poor').length;
  const id = 'INS-' + (idCounters.ins++);
  state.inspections.unshift({id, date, property, inspector, good, fair, poor, items: {...currentConditions}, comments: document.getElementById('ii_comments').value});
  addActivity('Inspection ' + id + ' completed at ' + property);
  showToast('Inspection saved — open it below to view the full checklist');
  document.getElementById('inspectionForm').style.display = 'none';
  document.getElementById('ii_property').value = '';
  document.getElementById('ii_inspector').value = '';
  document.getElementById('ii_comments').value = '';
  currentConditions = {};
  renderCategoryChecklist();
  lastSavedInspectionId = id;
  renderAll();
  const historyCard = document.getElementById('inspectionHistory');
  if(historyCard) historyCard.scrollIntoView({behavior:'smooth', block:'center'});
}
let expandedInspectionId = null;
let lastSavedInspectionId = null;
function toggleInspectionDetail(id){
  expandedInspectionId = expandedInspectionId === id ? null : id;
  renderInspections();
}
function deleteInspection(id){
  if(!confirm('Delete inspection ' + id + '?')) return;
  state.inspections = state.inspections.filter(i => i.id !== id);
  addActivity('Inspection ' + id + ' deleted');
  showToast('Deleted');
  renderAll();
}
function renderInspections(){
  const box = document.getElementById('inspectionHistory');
  if(!box) return;
  if(state.inspections.length === 0){
    box.innerHTML = '<p style="font-size:13px;color:var(--navy-400);">No inspections saved yet.</p>';
    return;
  }
  box.innerHTML = state.inspections.map(i => {
    const isOpen = expandedInspectionId === i.id;
    const isNew = lastSavedInspectionId === i.id;
    const items = i.items || {};
    const itemRows = Object.keys(items).length
      ? Object.entries(items).map(([cat,cond]) => `
          <div class="condition-row" style="padding:8px 4px;">
            <span style="font-size:12.5px;">${esc(cat)}</span>
            <span class="status-pill ${cond==='Good'?'status-Completed':cond==='Fair'?'status-InProgress':'status-Overdue'}">${cond}</span>
          </div>`).join('')
      : '<p style="font-size:12px;color:var(--navy-400); padding:8px 4px;">No individual category ratings were recorded for this inspection.</p>';
    return `
    <div class="list-item" style="flex-direction:column; align-items:stretch; ${isNew ? 'border-color:var(--gold-500); box-shadow:0 0 0 1px var(--gold-400);' : ''}">
      <div style="display:flex; justify-content:space-between; align-items:center; gap:10px; cursor:pointer;" onclick="toggleInspectionDetail('${i.id}')">
        <div><div class="t">${esc(i.property)} ${isNew ? '<span style="color:var(--gold-600); font-size:11px; font-weight:700;">· NEW</span>' : ''}</div><div class="s">${i.id} · ${i.date} · Inspector: ${esc(i.inspector)}</div></div>
        <div style="display:flex; gap:6px; align-items:center; flex-wrap:wrap;">
          <span class="status-pill status-Completed">${i.good} Good</span>
          <span class="status-pill status-InProgress">${i.fair} Fair</span>
          <span class="status-pill status-Overdue">${i.poor} Poor</span>
          <button class="icon-btn" onclick="event.stopPropagation(); toggleInspectionDetail('${i.id}')">${isOpen ? 'Close' : 'View'}</button>
          <button class="icon-btn danger" onclick="event.stopPropagation(); deleteInspection('${i.id}')">Delete</button>
        </div>
      </div>
      ${isOpen ? `<div style="margin-top:10px; border-top:1px solid var(--navy-50); padding-top:8px;">
          ${i.comments ? `<p style="font-size:12.5px; color:var(--navy-600); margin:0 0 8px;"><strong>Comments:</strong> ${esc(i.comments)}</p>` : ''}
          ${itemRows}
        </div>` : ''}
    </div>`;
  }).join('');
}

/* ============ CONTRACTORS ============ */
function resetContractorForm(){
  editingContractorId = null;
  document.getElementById('cc_status_field').style.display = 'none';
  document.getElementById('cc_name').value = '';
  document.getElementById('cc_company').value = '';
  document.getElementById('cc_scope').value = '';
  document.getElementById('cc_start').value = '';
  document.getElementById('cc_expected').value = '';
}
function saveContractor(){
  const name = document.getElementById('cc_name').value.trim();
  const company = document.getElementById('cc_company').value.trim();
  if(!name || !company){ showToast('Add a contractor name and company'); return; }
  const scope = document.getElementById('cc_scope').value.trim();
  const start = document.getElementById('cc_start').value || todayStr();
  const expected = document.getElementById('cc_expected').value || '-';
  if(editingContractorId){
    const rec = state.contractors.find(c => c.id === editingContractorId);
    rec.name=name; rec.company=company; rec.scope=scope; rec.start=start; rec.expected=expected;
    rec.status = document.getElementById('cc_status').value;
    addActivity('Contractor ' + rec.id + ' updated');
    showToast('Contractor updated');
  } else {
    const id = 'CT-' + (idCounters.ct++);
    state.contractors.unshift({id, name, company, scope, start, expected, status:'Working'});
    addActivity('Contractor ' + id + ' added — ' + company);
    showToast('Contractor saved — see it highlighted in the table below');
    lastSavedContractorId = id;
  }
  document.getElementById('contractorForm').style.display = 'none';
  resetContractorForm();
  renderAll();
  const table = document.getElementById('contractorTable');
  if(table) table.scrollIntoView({behavior:'smooth', block:'center'});
}
let lastSavedContractorId = null;
function editContractor(id){
  const rec = state.contractors.find(c => c.id === id);
  editingContractorId = id;
  document.getElementById('contractorForm').style.display = 'block';
  document.getElementById('cc_status_field').style.display = 'block';
  document.getElementById('cc_name').value = rec.name;
  document.getElementById('cc_company').value = rec.company;
  document.getElementById('cc_scope').value = rec.scope;
  document.getElementById('cc_start').value = rec.start;
  document.getElementById('cc_expected').value = rec.expected;
  document.getElementById('cc_status').value = rec.status;
  window.scrollTo(0,0);
}
function deleteContractor(id){
  if(!confirm('Delete contractor ' + id + '?')) return;
  state.contractors = state.contractors.filter(c => c.id !== id);
  addActivity('Contractor ' + id + ' deleted');
  showToast('Deleted');
  renderAll();
}
function updateContractorStatus(id, val){
  const rec = state.contractors.find(c => c.id === id);
  rec.status = val;
  addActivity('Contractor ' + id + ' set to ' + val);
  showToast('Status updated');
  renderAll();
}
function renderContractors(){
  const tbody = document.getElementById('contractorTable');
  if(!tbody) return;
  tbody.innerHTML = state.contractors.map(c => `
    <tr ${c.id === lastSavedContractorId ? 'style="background:var(--gold-50); box-shadow:inset 3px 0 0 var(--gold-500);"' : ''}>
      <td data-label="Company">${esc(c.company)}</td>
      <td data-label="Contact">${esc(c.name)}</td>
      <td data-label="Scope">${esc(c.scope)}</td>
      <td data-label="Start">${c.start}</td>
      <td data-label="Expected">${c.expected}</td>
      <td data-label="Status">
        <select class="status-select ${statusClass(c.status)}" onchange="updateContractorStatus('${c.id}', this.value)">
          ${['Working','Outstanding','Awaiting Sign-off','Completed'].map(s=>`<option ${s===c.status?'selected':''}>${s}</option>`).join('')}
        </select>
      </td>
      <td data-label="Actions"><div class="row-actions">
        <button class="icon-btn" onclick="editContractor('${c.id}')">Edit</button>
        <button class="icon-btn danger" onclick="deleteContractor('${c.id}')">Delete</button>
      </div></td>
    </tr>`).join('');

  const tiles = document.getElementById('contractorTiles');
  if(tiles){
    const working = state.contractors.filter(c=>c.status==='Working').length;
    const outstanding = state.contractors.filter(c=>c.status==='Outstanding').length;
    const awaiting = state.contractors.filter(c=>c.status==='Awaiting Sign-off').length;
    const completed = state.contractors.filter(c=>c.status==='Completed').length;
    tiles.innerHTML = `
      <div class="glass-card tile"><div class="n" style="color:var(--info);">${working}</div><div class="l">Working</div></div>
      <div class="glass-card tile"><div class="n" style="color:var(--overdue);">${outstanding}</div><div class="l">Outstanding</div></div>
      <div class="glass-card tile"><div class="n" style="color:var(--attention);">${awaiting}</div><div class="l">Awaiting Sign-off</div></div>
      <div class="glass-card tile"><div class="n" style="color:var(--complete);">${completed}</div><div class="l">Completed</div></div>`;
  }
}

/* ============ DELIVERIES ============ */
function resetDeliveryForm(){
  editingDeliveryId = null;
  document.getElementById('dd_supplier').value = '';
  document.getElementById('dd_qty').value = '';
  document.getElementById('dd_items').value = '';
  document.getElementById('dd_received').value = '';
  document.getElementById('dd_checked').value = '';
}
function saveDelivery(){
  const supplier = document.getElementById('dd_supplier').value.trim();
  const items = document.getElementById('dd_items').value.trim();
  if(!supplier || !items){ showToast('Add a supplier and items delivered'); return; }
  const qty = document.getElementById('dd_qty').value.trim() || '-';
  const received = document.getElementById('dd_received').value.trim() || '-';
  if(editingDeliveryId){
    const rec = state.deliveries.find(d => d.id === editingDeliveryId);
    rec.supplier=supplier; rec.items=items; rec.qty=qty; rec.received=received;
    addActivity('Delivery ' + rec.id + ' updated');
    showToast('Delivery updated');
  } else {
    const id = 'DL-' + (idCounters.dl++);
    state.deliveries.unshift({id, date: todayStr(), supplier, items, qty, received});
    addActivity('Delivery ' + id + ' received from ' + supplier);
    showToast('Delivery saved — see it highlighted in the table below');
    lastSavedDeliveryId = id;
  }
  document.getElementById('deliveryForm').style.display = 'none';
  resetDeliveryForm();
  renderAll();
  const table = document.getElementById('deliveryTable');
  if(table) table.scrollIntoView({behavior:'smooth', block:'center'});
}
let lastSavedDeliveryId = null;
function editDelivery(id){
  const rec = state.deliveries.find(d => d.id === id);
  editingDeliveryId = id;
  document.getElementById('deliveryForm').style.display = 'block';
  document.getElementById('dd_supplier').value = rec.supplier;
  document.getElementById('dd_qty').value = rec.qty;
  document.getElementById('dd_items').value = rec.items;
  document.getElementById('dd_received').value = rec.received;
  window.scrollTo(0,0);
}
function deleteDelivery(id){
  if(!confirm('Delete delivery ' + id + '?')) return;
  state.deliveries = state.deliveries.filter(d => d.id !== id);
  addActivity('Delivery ' + id + ' deleted');
  showToast('Deleted');
  renderAll();
}
function renderDeliveries(){
  const tbody = document.getElementById('deliveryTable');
  if(!tbody) return;
  tbody.innerHTML = state.deliveries.map(d => `
    <tr ${d.id === lastSavedDeliveryId ? 'style="background:var(--gold-50); box-shadow:inset 3px 0 0 var(--gold-500);"' : ''}>
      <td data-label="Date">${d.date}</td>
      <td data-label="Supplier">${esc(d.supplier)}</td>
      <td data-label="Items">${esc(d.items)}</td>
      <td data-label="Quantity">${esc(d.qty)}</td>
      <td data-label="Received By">${esc(d.received)}</td>
      <td data-label="Actions"><div class="row-actions">
        <button class="icon-btn" onclick="editDelivery('${d.id}')">Edit</button>
        <button class="icon-btn danger" onclick="deleteDelivery('${d.id}')">Delete</button>
      </div></td>
    </tr>`).join('');
}

/* ============ DASHBOARD ============ */
function renderDashboard(){
  const grid = document.getElementById('statGrid');
  if(!grid) return;
  const open = state.maintenance.filter(m=>m.status==='Open').length;
  const overdue = state.maintenance.filter(m=>m.status==='Overdue').length;
  const completed = state.maintenance.filter(m=>m.status==='Completed').length;
  const onSite = state.contractors.filter(c=>c.status==='Working').length;
  const outstandingTasks = state.contractors.filter(c=>c.status==='Outstanding' || c.status==='Awaiting Sign-off').length;
  const deliveriesToday = state.deliveries.filter(d=>d.date===todayStr()).length;

  grid.innerHTML = `
    <div class="glass-card stat-card"><div class="stat-icon info">🔧</div><div><div class="stat-value">${open}</div><div class="stat-label">Open Maintenance</div></div></div>
    <div class="glass-card stat-card"><div class="stat-icon overdue">⚠</div><div><div class="stat-value">${overdue}</div><div class="stat-label">Overdue Maintenance</div></div></div>
    <div class="glass-card stat-card"><div class="stat-icon complete">✓</div><div><div class="stat-value">${completed}</div><div class="stat-label">Completed Maintenance</div></div></div>
    <div class="glass-card stat-card"><div class="stat-icon attention">📅</div><div><div class="stat-value">${upcomingInspectionsCount}</div><div class="stat-label">Upcoming Inspections</div></div></div>
    <div class="glass-card stat-card"><div class="stat-icon neutral">📋</div><div><div class="stat-value">${state.inspections.length}</div><div class="stat-label">Recent Inspections</div></div></div>
    <div class="glass-card stat-card"><div class="stat-icon info">👷</div><div><div class="stat-value">${onSite}</div><div class="stat-label">Contractors On Site</div></div></div>
    <div class="glass-card stat-card"><div class="stat-icon attention">📝</div><div><div class="stat-value">${outstandingTasks}</div><div class="stat-label">Outstanding Contractor Tasks</div></div></div>
    <div class="glass-card stat-card"><div class="stat-icon complete">📦</div><div><div class="stat-value">${deliveriesToday}</div><div class="stat-label">Deliveries Received Today</div></div></div>`;

  const rm = document.getElementById('dashRecentMaintenance');
  rm.innerHTML = state.maintenance.slice(0,4).map(m => `
    <div class="list-item"><div><div class="t">${esc(m.fault)}</div><div class="s">${esc(m.property)} · ${esc(m.area)} · ${m.id}</div></div><span class="status-pill ${statusClass(m.status)}">${m.status}</span></div>`).join('') || '<p style="font-size:13px;color:var(--navy-400);">No maintenance records yet.</p>';

  const feed = document.getElementById('dashFeed');
  feed.innerHTML = state.activity.map(a => `
    <div class="list-item" style="border-left:3px solid var(--info);"><div><div class="t" style="font-weight:400;">${esc(a.text)}</div><div class="s">${a.time}</div></div></div>`).join('');

  const di = document.getElementById('dashInspections');
  di.innerHTML = state.inspections.slice(0,3).map(i => `
    <div class="list-item"><div><div class="t">${esc(i.property)}</div><div class="s">${i.date} · ${esc(i.inspector)}</div></div></div>`).join('') || '<p style="font-size:13px;color:var(--navy-400);">No inspections yet.</p>';

  const dc = document.getElementById('dashContractors');
  dc.innerHTML = state.contractors.slice(0,3).map(c => `
    <div class="list-item"><div><div class="t">${esc(c.company)}</div><div class="s">${esc(c.scope)}</div></div><span class="status-pill ${statusClass(c.status)}">${c.status}</span></div>`).join('') || '<p style="font-size:13px;color:var(--navy-400);">No contractors yet.</p>';

  const dd = document.getElementById('dashDeliveries');
  dd.innerHTML = state.deliveries.slice(0,5).map(d => `
    <tr><td>${d.date}</td><td>${esc(d.supplier)}</td><td>${esc(d.items)}</td><td>${esc(d.qty)}</td><td>${esc(d.received)}</td></tr>`).join('');
}

/* ============ RENDER ALL ============ */
function renderAll(){
  renderDashboard();
  renderMaintenance();
  renderInspections();
  renderContractors();
  renderDeliveries();
}
renderCategoryChecklist();
renderAll();

// Register a minimal inline service worker (as a Blob, so no separate .js file is needed).
// This is what lets Chrome/Edge/Android show the native "Install" prompt, not just
// Safari's Add to Home Screen. Wrapped safely — if the browser or context doesn't
// support it, it just quietly does nothing and the rest of the app is unaffected.
if ("serviceWorker" in navigator && (location.protocol === "http:" || location.protocol === "https:")) {
  const swCode = `
    self.addEventListener('install', (e) => self.skipWaiting());
    self.addEventListener('activate', (e) => self.clients.claim());
    self.addEventListener('fetch', (e) => e.respondWith(fetch(e.request).catch(() => caches.match(e.request))));
  `;
  try {
    const blob = new Blob([swCode], { type: "application/javascript" });
    const swUrl = URL.createObjectURL(blob);
    window.addEventListener("load", () => {
      navigator.serviceWorker.register(swUrl).catch(() => {});
    });
  } catch (e) { /* no-op — install still works via the browser's manual Install menu */ }
}
</script>

</body>
</html>
