            <input type="file" accept="image/*" capture="environment" id="mm_capture" style="display:none" onchange="handlePhoto(event,'mm')">
            <button class="btn-outline" type="button" onclick="document.getElementById('mm_capture').click()">📷 Capture Live Photo</button>
            <input type="file" accept="image/*" id="mm_upload" style="display:none" onchange="handlePhoto(event,'mm')">
            <button class="btn-outline" type="button" onclick="document.getElementById('mm_upload').click()">⬆ Upload Existing Photo</button>
          </div>
