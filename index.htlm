<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<title>Tribal Kingdom</title>

<!-- PWA: everything (manifest + icon) is embedded right here as data — no separate files needed.
     This is what lets the app be added to a phone/desktop home screen with its own icon,
     opening full-screen with no browser address bar. -->
<link rel="manifest" href="data:application/manifest+json;base64,">
<meta name="theme-color" content="#0A1930">
<link rel="icon" href="data:image/png;base64," type="image/png">
<link rel="apple-touch-icon" href="data:image/png;base64,">
<meta name="apple-mobile-web-app-capable" content="yes">
<meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
<meta name="apple-mobile-web-app-title" content="Tribal Kingdom">
<meta name="mobile-web-app-capable" content="yes">

<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Fraunces:wght@400;500;600;700&family=Inter:wght@400;500;600&family=IBM+Plex+Mono:wght@400;500&display=swap" rel="stylesheet">
<style>
  :root{
    --navy-950:#060F1E; --navy-900:#0A1930; --navy-800:#0F2038; --navy-700:#1B2E4C;
    --navy-600:#2C4468; --navy-500:#3E5C87; --navy-400:#5E76AB; --navy-300:#8698C0;
    --navy-200:#AEBBD6; --navy-100:#D6DDEB; --navy-50:#EEF1F7;
    --gold-900:#3A2E0F; --gold-700:#8C6D25; --gold-600:#BD9636; --gold-500:#E0B84E;
    --gold-400:#EFC968; --gold-300:#F4D98A; --gold-200:#F8E6B3; --gold-100:#FBF0D6; --gold-50:#FDF8ED;
    --gold-shine:linear-gradient(135deg, #F6E2A0 0%, #E0B84E 45%, #BD9636 100%);
    --navy-shine:linear-gradient(135deg, #1B2E4C 0%, #0A1930 60%, #060F1E 100%);
    --complete:#3F9C6D; --attention:#D6A339; --overdue:#C25450; --info:#4E7FBF;
  }
  *{box-sizing:border-box;}
  body{margin:0; font-family:'Inter',sans-serif; color:var(--navy-900); background:linear-gradient(160deg,#EEF1F7 0%,#DCE3EF 55%,#CBD5E5 100%);}
  h1,h2,h3,h4{font-family:'Fraunces',serif; margin:0;}
  .mono{font-family:'IBM Plex Mono',monospace;}


  .screen{display:none;} .screen.active{display:block;}
  .glass-card{background:rgba(255,255,255,.7); backdrop-filter:blur(20px); -webkit-backdrop-filter:blur(20px); border:1px solid rgba(255,255,255,.6); border-radius:20px; box-shadow:0 8px 32px rgba(10,25,48,.12);}
  .glass-card-dark{background:rgba(255,255,255,.06); backdrop-filter:blur(20px); -webkit-backdrop-filter:blur(20px); border:1px solid rgba(255,255,255,.1); border-radius:20px; box-shadow:0 8px 32px rgba(0,0,0,.35);}
  .gold-divider{height:1px; width:48px; background:var(--gold-500); margin:12px auto;}

  .login-wrap{min-height:88vh; position:relative; overflow:hidden; display:flex; flex-direction:column; align-items:center; justify-content:center; padding:48px 20px; background:radial-gradient(circle at 15% 0%, #1B2E4C 0%, #0A1930 45%, #060F1E 100%);}
  .crest{width:80px; height:80px; border-radius:50%; border:1px solid var(--gold-400); display:flex; align-items:center; justify-content:center; margin-bottom:28px; position:relative; box-shadow:0 0 24px rgba(224,184,78,.35), inset 0 0 16px rgba(224,184,78,.08);}
  .crest::before{content:'';position:absolute; inset:6px; border:1px solid rgba(224,184,78,.4); border-radius:50%;}
  .crest span{background:var(--gold-shine); -webkit-background-clip:text; background-clip:text; color:transparent; font-family:'Fraunces',serif; font-size:22px; letter-spacing:.15em; filter:drop-shadow(0 0 6px rgba(224,184,78,.3));}
  .login-title{color:#fff; font-size:40px; font-weight:500; text-align:center;}
  .login-sub{color:var(--navy-200); font-size:12px; text-transform:uppercase; letter-spacing:.25em; text-align:center; margin:0;}
  .login-card{width:100%; max-width:420px; padding:36px 32px; margin-top:36px;}
  .login-card label{display:block; font-size:11px; text-transform:uppercase; letter-spacing:.05em; color:var(--navy-200); margin-bottom:6px; font-weight:500;}
  .login-card input{width:100%; border:1px solid rgba(255,255,255,.15); background:rgba(255,255,255,.05); color:#fff; padding:12px 14px; border-radius:10px; font-size:14px; margin-bottom:18px; font-family:'Inter',sans-serif;}
  .login-card input::placeholder{color:var(--navy-300);}
  .btn-gold{width:100%; background:var(--gold-shine); color:var(--navy-950); border:none; padding:13px; border-radius:10px; font-weight:700; font-size:13px; text-transform:uppercase; letter-spacing:.05em; cursor:pointer; box-shadow:0 6px 20px rgba(224,184,78,.35); transition:.2s;}
  .btn-gold:hover{box-shadow:0 8px 26px rgba(224,184,78,.5); transform:translateY(-1px);}
  .login-footer{text-align:center; margin-top:32px; color:var(--navy-300); font-size:12px;}
  .login-footer .gold{color:var(--gold-400);}

  .app-shell{display:flex; min-height:80vh;}
  .sidebar{width:230px; flex-shrink:0; background:rgba(255,255,255,.6); backdrop-filter:blur(20px); border-right:1px solid var(--navy-100); display:flex; flex-direction:column;}
  .sidebar .brand{display:flex; align-items:center; gap:10px; padding:20px 18px;}
  .sidebar .brand .mark{width:36px; height:36px; border-radius:50%; border:1px solid var(--gold-500); display:flex; align-items:center; justify-content:center; font-family:'Fraunces',serif; font-size:13px; color:var(--gold-600); flex-shrink:0;}
  .sidebar .brand .names p{margin:0; line-height:1.25;}
  .sidebar .brand .names p:first-child{font-family:'Fraunces',serif; font-size:14px; font-weight:500;}
  .sidebar .brand .names p:last-child{font-size:9px; letter-spacing:.14em; text-transform:uppercase; color:var(--navy-400);}
  .sidebar nav{flex:1; padding:6px 10px;}
  .sidebar nav a{display:flex; align-items:center; gap:10px; padding:10px 12px; border-radius:10px; font-size:13.5px; color:var(--navy-600); text-decoration:none; margin-bottom:2px; cursor:pointer;}
  .sidebar nav a.current{background:var(--navy-shine); color:#fff; box-shadow:inset 3px 0 0 var(--gold-500);}
  .sidebar nav a .dot{width:6px;height:6px;border-radius:50%;background:var(--navy-300); flex-shrink:0;}
  .sidebar nav a.current .dot{background:var(--gold-400);}
  .sidebar .foot{border-top:1px solid var(--navy-100); padding:14px 18px; font-size:10.5px; color:var(--navy-400);}
  .sidebar .foot .gold{color:var(--gold-600);}

  .main{flex:1; display:flex; flex-direction:column; min-width:0;}
  .topbar{display:flex; align-items:center; justify-content:space-between; gap:16px; padding:22px 28px; background:var(--navy-shine); flex-wrap:wrap; box-shadow:0 4px 20px rgba(6,15,30,.25);}
  .topbar h2{font-size:24px; font-weight:500; color:#fff;}
  .topbar p{margin:4px 0 0; color:var(--navy-200); font-size:13.5px;}
  .avatar{width:30px;height:30px;border-radius:50%;background:var(--gold-shine); color:var(--navy-950); display:flex; align-items:center; justify-content:center; font-size:12px; font-weight:700; box-shadow:0 0 0 2px rgba(255,255,255,.15);}
  .content{padding:24px 28px; flex:1;}

  .stat-grid{display:grid; grid-template-columns:repeat(4,1fr); gap:16px; margin-bottom:24px;}
  .hero-banner{display:flex; align-items:center; justify-content:space-between; gap:20px; background:var(--navy-shine); border-radius:20px; padding:26px 30px; margin-bottom:22px; box-shadow:0 10px 30px rgba(6,15,30,.3); position:relative; overflow:hidden;}
  .hero-banner::before{content:''; position:absolute; top:-40%; right:-10%; width:220px; height:220px; border-radius:50%; background:radial-gradient(circle, rgba(224,184,78,.18) 0%, transparent 70%);}
  .hero-eyebrow{color:var(--gold-400); font-size:11px; text-transform:uppercase; letter-spacing:.2em; margin:0 0 6px; font-weight:600;}
  .hero-title{color:#fff; font-size:26px; font-weight:500; margin:0;}
  .hero-sub{color:var(--navy-200); font-size:13px; margin:6px 0 0;}
  .hero-crest{width:56px; height:56px; border-radius:50%; border:1px solid var(--gold-400); display:flex; align-items:center; justify-content:center; color:var(--gold-400); font-family:'Fraunces',serif; font-size:16px; letter-spacing:.1em; flex-shrink:0; box-shadow:0 0 20px rgba(224,184,78,.25); position:relative; z-index:1;}
  .stat-card{display:flex; align-items:center; gap:14px; padding:18px; transition:.2s; border-top:2px solid transparent;}
  .stat-card:hover{border-top:2px solid var(--gold-500); transform:translateY(-2px); box-shadow:0 10px 24px rgba(10,25,48,.14);}
  .stat-icon{width:44px;height:44px;border-radius:12px; display:flex; align-items:center; justify-content:center; font-size:18px; flex-shrink:0;}
  .stat-icon.info{background:rgba(78,127,191,.1); color:var(--info);}
  .stat-icon.overdue{background:rgba(194,84,80,.1); color:var(--overdue);}
  .stat-icon.complete{background:rgba(63,156,109,.1); color:var(--complete);}
  .stat-icon.attention{background:rgba(214,163,57,.1); color:var(--attention);}
  .stat-icon.neutral{background:var(--navy-50); color:var(--navy-700);}
  .stat-value{font-family:'Fraunces',serif; font-size:24px; font-weight:500;}
  .stat-label{font-size:11.5px; color:var(--navy-500); margin-top:1px;}

  .row-2col{display:grid; grid-template-columns:2fr 1fr; gap:20px; margin-bottom:20px;}
  .row-3col{display:grid; grid-template-columns:repeat(3,1fr); gap:20px; margin-bottom:20px;}
  .card-pad{padding:20px;}
  .card-title{font-size:15.5px; font-weight:500; margin-bottom:14px; display:flex; justify-content:space-between; align-items:center; padding-bottom:10px; border-bottom:1px solid var(--navy-50); position:relative;}
  .card-title::after{content:''; position:absolute; left:0; bottom:-1px; width:36px; height:2px; background:var(--gold-shine);}
  .card-title a{font-size:12px; color:var(--gold-600); text-decoration:none; font-weight:600; cursor:pointer;}

  .list-item{border:1px solid var(--navy-50); background:rgba(255,255,255,.6); border-radius:12px; padding:12px 14px; margin-bottom:10px; display:flex; justify-content:space-between; align-items:center; gap:10px;}
  .list-item .t{font-size:13.5px; font-weight:500;}
  .list-item .s{font-size:11.5px; color:var(--navy-400); margin-top:2px;}

  .status-pill{padding:4px 10px; border-radius:999px; font-size:11px; font-weight:600; white-space:nowrap; border:none;}
  .status-Open{background:rgba(78,127,191,.1); color:var(--info);}
  .status-InProgress,.status-WaitingContractor,.status-WaitingParts{background:rgba(214,163,57,.1); color:var(--attention);}
  .status-Completed{background:rgba(63,156,109,.1); color:var(--complete);}
  .status-Overdue,.status-Outstanding{background:rgba(194,84,80,.1); color:var(--overdue);}
  .status-Working,.status-AwaitingSignoff{background:rgba(78,127,191,.1); color:var(--info);}
  select.status-select{font-size:11px; font-weight:600; border-radius:999px; padding:4px 8px; cursor:pointer; font-family:'Inter',sans-serif;}

  table{width:100%; border-collapse:collapse; font-size:13px;}
  thead th{text-align:left; font-size:10.5px; text-transform:uppercase; letter-spacing:.05em; color:var(--navy-400); padding-bottom:8px; font-weight:600;}
  tbody td{padding:10px 8px; border-top:1px solid var(--navy-50); color:var(--navy-700); vertical-align:middle;}
  .table-wrap{overflow-x:auto;}
  .row-actions{display:flex; gap:6px;}
  .icon-btn{background:transparent; border:1px solid var(--navy-100); border-radius:8px; padding:5px 8px; cursor:pointer; font-size:12px; color:var(--navy-500);}
  .icon-btn:hover{border-color:var(--gold-400); color:var(--gold-600);}
  .icon-btn.danger:hover{border-color:var(--overdue); color:var(--overdue);}

  .action-grid{display:grid; grid-template-columns:1fr 1fr; gap:10px;}
  .action-btn{display:flex; flex-direction:column; gap:10px; align-items:flex-start; padding:14px; border:1px solid var(--navy-100); background:rgba(255,255,255,.7); border-radius:12px; cursor:pointer;}
  .action-btn .ico{width:32px;height:32px;border-radius:8px; background:var(--navy-900); color:var(--gold-400); display:flex; align-items:center; justify-content:center; font-size:14px;}
  .action-btn span.label{font-size:12.5px; font-weight:500;}

  .form-card{padding:22px; margin-bottom:20px;}
  .form-grid{display:grid; grid-template-columns:1fr 1fr; gap:14px;}
  .field label{display:block; font-size:11px; text-transform:uppercase; letter-spacing:.04em; color:var(--navy-500); margin-bottom:6px; font-weight:600;}
  .field input, .field select, .field textarea{width:100%; border:1px solid var(--navy-100); background:rgba(255,255,255,.8); padding:10px 12px; border-radius:10px; font-size:13.5px; font-family:'Inter',sans-serif; color:var(--navy-800);}
  .btn-row{display:flex; justify-content:flex-end; gap:10px; margin-top:16px; flex-wrap:wrap;}
  .btn-outline{background:transparent; border:1px solid var(--navy-100); color:var(--navy-600); padding:10px 16px; border-radius:10px; font-size:13px; cursor:pointer;}
  .btn-primary{background:var(--navy-shine); color:#fff; border:none; padding:10px 16px; border-radius:10px; font-size:13px; cursor:pointer; display:inline-flex; align-items:center; gap:6px; box-shadow:0 4px 14px rgba(10,25,48,.25); transition:.2s;}
  .btn-primary:hover{box-shadow:0 6px 18px rgba(10,25,48,.35); transform:translateY(-1px);}
  .btn-gold-sm{background:var(--gold-shine); color:var(--navy-950); border:none; padding:10px 18px; border-radius:10px; font-size:13px; font-weight:700; cursor:pointer; box-shadow:0 4px 14px rgba(224,184,78,.35); transition:.2s;}
  .btn-gold-sm:hover{box-shadow:0 6px 18px rgba(224,184,78,.5); transform:translateY(-1px);}
  .photo-row{display:flex; gap:10px; flex-wrap:wrap; align-items:center; margin-top:4px;}
  .photo-preview{display:flex; align-items:center; gap:10px; margin-top:10px;}
  .photo-preview img{width:56px; height:56px; object-fit:cover; border-radius:10px; border:1px solid var(--navy-100);}
  .photo-preview .x{cursor:pointer; color:var(--overdue); font-size:12px; border:1px solid var(--navy-100); border-radius:8px; padding:4px 8px; background:#fff;}
  .cam-icon{font-size:12px; margin-left:6px;}

  .summary-tiles{display:grid; grid-template-columns:repeat(4,1fr); gap:14px; margin-bottom:20px;}
  .tile{padding:16px;}
  .tile .n{font-family:'Fraunces',serif; font-size:24px; font-weight:500;}
  .tile .l{font-size:11.5px; color:var(--navy-500); margin-top:2px;}

  .condition-row{display:flex; justify-content:space-between; align-items:center; padding:11px 14px; border-bottom:1px solid var(--navy-50); font-size:13px;}
  .cond-btns{display:flex; gap:6px;}
  .cond-btn{border-radius:999px; padding:4px 11px; font-size:11px; font-weight:600; border:1px solid var(--navy-100); background:transparent; color:var(--navy-400); cursor:pointer;}
  .cond-btn.good.sel{background:var(--complete); color:#fff; border-color:var(--complete);}
  .cond-btn.fair.sel{background:var(--attention); color:#fff; border-color:var(--attention);}
  .cond-btn.poor.sel{background:var(--overdue); color:#fff; border-color:var(--overdue);}

  .mobile-toggle{display:none;}
  .footer-strip{border-top:1px solid var(--navy-100); text-align:center; padding:14px; font-size:11px; color:var(--navy-400);}
  .toast{position:fixed; bottom:20px; left:50%; transform:translateX(-50%) translateY(20px); background:var(--navy-950); color:#fff; padding:11px 18px; border-radius:10px; font-size:13px; opacity:0; transition:.25s; z-index:100; pointer-events:none;}
  .toast.show{opacity:1; transform:translateX(-50%) translateY(0);}

  @media (max-width: 1024px){ .stat-grid{grid-template-columns:repeat(3,1fr);} .row-2col{grid-template-columns:1fr;} .row-3col{grid-template-columns:1fr 1fr;} }
  @media (max-width: 820px){
    .app-shell{position:relative;}
    .sidebar{position:fixed; top:0; left:0; height:100%; z-index:40; transform:translateX(-100%); transition:transform .25s ease; box-shadow:0 0 40px rgba(0,0,0,.25); width:250px;}
    .sidebar.open{transform:translateX(0);}
    .mobile-toggle{display:flex; align-items:center; justify-content:center; width:38px; height:38px; border-radius:10px; border:1px solid rgba(255,255,255,.25); background:rgba(255,255,255,.1); font-size:16px; cursor:pointer; color:#fff; flex-shrink:0;}
    .scrim{display:none; position:fixed; inset:0; background:rgba(6,15,30,.45); z-index:30;}
    .scrim.show{display:block;}
    .stat-grid{grid-template-columns:repeat(2,1fr);} .row-3col{grid-template-columns:1fr;} .summary-tiles{grid-template-columns:repeat(2,1fr);}
    .form-grid{grid-template-columns:1fr;} .action-grid{grid-template-columns:1fr 1fr;}
    .topbar{padding:16px 18px;} .content{padding:16px 18px;} .login-title{font-size:32px;}
  }
  @media (max-width: 480px){
    .stat-grid{grid-template-columns:1fr 1fr;} .summary-tiles{grid-template-columns:1fr 1fr;} .action-grid{grid-template-columns:1fr;}
    .login-card{padding:26px 20px;}
    .hero-banner{flex-direction:column; align-items:flex-start; text-align:left; padding:22px;}
    .hero-crest{position:absolute; top:20px; right:20px;}
    thead{display:none;} table, tbody, tr, td{display:block; width:100%;}
    tbody tr{border:1px solid var(--navy-50); border-radius:12px; margin-bottom:10px; padding:8px; background:rgba(255,255,255,.6);}
    tbody td{border-top:none; padding:4px 6px;}
    tbody td:before{content:attr(data-label); display:block; font-size:10px; text-transform:uppercase; color:var(--navy-400); letter-spacing:.04em; margin-bottom:2px;}
  }
</style>
</head>
<body>

<section class="screen active" id="screen-login">
  <div class="login-wrap">
    <div class="crest"><span>TK</span></div>
    <h1 class="login-title">Tribal Kingdom</h1>
    <div class="gold-divider"></div>
    <p class="login-sub">Property Management Platform</p>
    <form class="glass-card-dark login-card" onsubmit="return false;">
      <label>Email address</label>
      <input type="email" placeholder="you@tribalkingdom.com">
      <label>Password</label>
      <input type="password" placeholder="••••••••">
      <button class="btn-gold" type="button" onclick="showScreen('dashboard')">Enter Platform</button>
    </form>
    <div class="login-footer">Developed by <span class="gold">Smart Design Business Operations</span><br><span style="font-size:10.5px;">Created by Brad · Version 1.0</span></div>
  </div>
</section>

<section class="screen" id="screen-dashboard">
  <div class="app-shell">
    <div class="scrim" onclick="closeSidebar()"></div>
    <aside class="sidebar" id="sidebar-dashboard">
      <div class="brand"><div class="mark">TK</div><div class="names"><p>Tribal Kingdom</p><p>Facilities Ops</p></div></div>
      <nav>
        <a class="current"><span class="dot"></span>Dashboard</a>
        <a onclick="showScreen('maintenance')"><span class="dot"></span>Maintenance</a>
        <a onclick="showScreen('inspections')"><span class="dot"></span>Inspections</a>
        <a onclick="showScreen('contractors')"><span class="dot"></span>Contractors</a>
        <a onclick="showScreen('deliveries')"><span class="dot"></span>Deliveries</a>
        <a onclick="showScreen('reports')"><span class="dot"></span>Reports</a>
      </nav>
      <div class="foot">Developed by <span class="gold">Smart Design Business Operations</span><br>Created by Brad · Version 1.0</div>
    </aside>
    <div class="main">
      <div class="topbar">
        <div style="display:flex;align-items:center;gap:12px;">
          <button class="mobile-toggle" onclick="openSidebar('dashboard')">☰</button>
          <div><h2>Dashboard</h2><p>Operational status across all Tribal Kingdom properties</p></div>
        </div>
        <div class="avatar">B</div>
      </div>
      <div class="content">
        <div class="hero-banner">
          <div>
            <p class="hero-eyebrow">Executive Overview</p>
            <h3 class="hero-title">Good day, Brad</h3>
            <p class="hero-sub">Here's where Tribal Kingdom stands across every property, right now.</p>
          </div>
          <div class="hero-crest">TK</div>
        </div>
        <div class="stat-grid" id="statGrid"></div>
        <div class="row-2col">
          <div class="glass-card card-pad">
            <div class="card-title"><span>Recent Maintenance Activity</span><a onclick="showScreen('maintenance')">View all</a></div>
            <div id="dashRecentMaintenance"></div>
          </div>
          <div class="glass-card card-pad">
            <div class="card-title">Recent Activity Feed</div>
            <div id="dashFeed"></div>
          </div>
        </div>
        <div class="row-3col">
          <div class="glass-card card-pad">
            <div class="card-title">Inspection Status</div>
            <div id="dashInspections"></div>
          </div>
          <div class="glass-card card-pad">
            <div class="card-title">Contractor Status</div>
            <div id="dashContractors"></div>
          </div>
          <div class="glass-card card-pad">
            <div class="card-title">Quick Actions</div>
            <div class="action-grid">
              <div class="action-btn" onclick="showScreen('maintenance')"><div class="ico">🔧</div><span class="label">Log Maintenance Issue</span></div>
              <div class="action-btn" onclick="showScreen('inspections')"><div class="ico">📋</div><span class="label">New Inspection</span></div>
              <div class="action-btn" onclick="showScreen('contractors')"><div class="ico">👷</div><span class="label">Add Contractor</span></div>
              <div class="action-btn" onclick="showScreen('deliveries')"><div class="ico">📦</div><span class="label">Record Delivery</span></div>
            </div>
          </div>
        </div>
        <div class="glass-card card-pad">
          <div class="card-title">Delivery Activity</div>
          <div class="table-wrap"><table><thead><tr><th>Date</th><th>Supplier</th><th>Items</th><th>Qty</th><th>Received By</th></tr></thead><tbody id="dashDeliveries"></tbody></table></div>
        </div>
